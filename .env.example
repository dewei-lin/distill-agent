# Distill Agent — environment template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git (it's in .gitignore).

# ============================================================
# Anthropic / Claude API
# ============================================================
# Required only for the web demo (web/backend).
# The Claude Code skill path does NOT need this — Claude Code uses
# the user's own Claude Code session for inference.
#
# Get a key at: https://console.anthropic.com/  (Settings -> API Keys)
# Recommended: set a monthly usage limit under Plans & Billing -> Limits.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection for the web demo.
# Defaults below are sensible; override only if you want to pin a version.
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_MAIN=claude-sonnet-4-6
ANTHROPIC_MODEL_PLANNER=claude-opus-4-6

# ============================================================
# Web server
# ============================================================
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Where uploaded datasets and session artifacts get written.
# Relative to the repo root.
RUN_ARTIFACTS_DIR=./run_artifacts

# CORS — comma-separated list of allowed origins for the frontend.
# For local dev the default below is fine.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
